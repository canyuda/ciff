# =============================================
# Ciff Deployment Environment Variables
# Copy this file to .env and fill in real values
# =============================================

# --- Database ---
MYSQL_PASSWORD=123456

# --- Redis ---
REDIS_PASSWORD=

# --- PostgreSQL + PGVector ---
PGVECTOR_PASSWORD=postgres

# --- Authentication ---
# JWT secret key (min 32 chars, generate with: openssl rand -base64 32)
SA_TOKEN_JWT_SECRET_KEY=change-me-in-production-generate-a-random-string

# Admin default credentials (used on first startup)
CIFF_ADMIN_USERNAME=admin
CIFF_ADMIN_PASSWORD=admin123

# --- API Key Encryption ---
# Optional: additional secret for API key generation
CIFF_API_KEY_SECRET=

# --- GitHub OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost/api/auth/github/callback

# --- Frontend ---
CIFF_FRONTEND_URL=http://localhost
